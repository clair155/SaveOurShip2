<Defs>
	
  <RecipeDef>
    <defName>MakeAntigrainWarheadx4</defName>
    <label>make antigrain warhead x4</label>
    <description>Craft 4 antigrain warhead.</description>
    <jobString>Making antigrain warheads.</jobString>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <allowMixingIngredients>true</allowMixingIngredients>
    <workAmount>8000</workAmount>
    <targetCountAdjustment>20</targetCountAdjustment>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>80</count>
      </li>
	  <li>
        <filter>
          <thingDefs>
            <li>ArchotechExoticParticles</li>
          </thingDefs>
        </filter>
        <count>24</count>
      </li>
	  <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>8</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
		<li>ArchotechExoticParticles</li>
		<li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Shell_AntigrainWarhead>4</Shell_AntigrainWarhead>
    </products>
    <workSkill>Crafting</workSkill>
	<recipeUsers>
		<li>TableMachining</li>
	</recipeUsers>
	<skillRequirements>
		<Crafting>12</Crafting>
	</skillRequirements>
    <researchPrerequisites><li>ArchotechAntimatter</li></researchPrerequisites>
  </RecipeDef>
